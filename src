"""
data_cleaning.py

Purpose:
This script loads a messy sales dataset, cleans common data quality issues,
and saves the cleaned dataset to the processed folder.

Cleaning tasks include:
- Standardizing column names
- Removing extra whitespace
- Handling missing values
- Removing invalid rows
"""

import pandas as pd
import numpy as np


# Copilot-assisted function:
# This function should load a CSV file and return a pandas DataFrame.
def load_data(file_path: str) -> pd.DataFrame:
    try:
        df = pd.read_csv(file_path)
        print(f"Loaded dataset with {df.shape[0]} rows and {df.shape[1]} columns.")
        return df
    except FileNotFoundError:
        print("Error: File not found.")
        raise


# Copilot-assisted function:
# This function should standardize column names by making them lowercase
# and replacing spaces with underscores.
def clean_column_names(df: pd.DataFrame) -> pd.DataFrame:
    df.columns = (
        df.columns
        .str.strip()
        .str.lower()
        .str.replace(" ", "_")
    )
    return df


# This function cleans text columns by removing extra spaces,
# quotation marks, and inconsistent capitalization.
def clean_text_columns(df: pd.DataFrame) -> pd.DataFrame:

    text_columns = ["prodname", "category"]

    for col in text_columns:
        df[col] = (
            df[col]
            .astype(str)
            .str.replace('"', '', regex=False)
            .str.strip()
            .str.replace(r"\s+", " ", regex=True)
            .str.title()
        )

    return df


# Copilot-assisted function:
# This function handles missing values in price and quantity columns.
# Missing numeric values are filled using median values.
def handle_missing_values(df: pd.DataFrame) -> pd.DataFrame:

    df["price"] = pd.to_numeric(df["price"], errors="coerce")
    df["qty"] = pd.to_numeric(df["qty"], errors="coerce")

    # Fill missing prices with median price
    df["price"] = df["price"].fillna(df["price"].median())

    # Fill missing quantities with median quantity
    df["qty"] = df["qty"].fillna(df["qty"].median())

    return df


# This function removes rows with invalid values.
# Negative prices and quantities are considered data entry errors.
def remove_invalid_rows(df: pd.DataFrame) -> pd.DataFrame:

    df = df[df["price"] >= 0]
    df = df[df["qty"] >= 0]

    return df


# This function removes duplicate records
# to avoid counting the same sale multiple times.
def remove_duplicates(df: pd.DataFrame) -> pd.DataFrame:

    df = df.drop_duplicates()

    return df


# This function converts the date column into a proper datetime format.
def clean_dates(df: pd.DataFrame) -> pd.DataFrame:

    df["date_sold"] = pd.to_datetime(df["date_sold"], errors="coerce")

    return df


if __name__ == "__main__":

    raw_path = "data/raw/sales_data_raw.csv"
    cleaned_path = "data/processed/sales_data_clean.csv"

    # Load raw dataset
    df_raw = load_data(raw_path)

    # Standardize column names
    df_clean = clean_column_names(df_raw)

    # Clean product and category text fields
    df_clean = clean_text_columns(df_clean)

    # Handle missing values
    df_clean = handle_missing_values(df_clean)

    # Remove invalid rows
    df_clean = remove_invalid_rows(df_clean)

    # Remove duplicate records
    df_clean = remove_duplicates(df_clean)

    # Clean date column
    df_clean = clean_dates(df_clean)

    # Save cleaned dataset
    df_clean.to_csv(cleaned_path, index=False)

    print("\nCleaning complete.")
    print("First few cleaned rows:\n")
    print(df_clean.head())
